# AWS Credentials
# Used by boto3 to authenticate with the AWS Pricing API (Pricing API / Savings Plans API).
# You can also rely on the default AWS credential chain
# (Lambda execution role, ~/.aws/credentials, environment variables, etc.).

AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY_HERE

# Optional: If you use temporary credentials (STS)
# AWS_SESSION_TOKEN=YOUR_SESSION_TOKEN_HERE

# Slack Bot Credentials (required for the Slack Lambda integration)
# Create a Slack App at https://api.slack.com/apps with:
#   - Bot Token (xoxb-...) with files:read, chat:write, channels:history scopes
#   - Signing Secret from the App Credentials page
SLACK_BOT_TOKEN=xoxb-YOUR-BOT-TOKEN-HERE
SLACK_SIGNING_SECRET=YOUR-SIGNING-SECRET-HERE
